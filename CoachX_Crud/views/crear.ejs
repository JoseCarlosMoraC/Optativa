<%- include("templates/cabecera", {subtitulo: 'Nuevo Jugador - CoachX' }) %>
    <div class="container">
        <h1>Crear nuevo Jugador</h1>
        <form action="/jugador" class="my-2" method="POST">
            <input type="text" placeholder="Nombre" class="form-control my-2" name="nombre">
            <input type="text" placeholder="Apellidos" class="form-control my-2" name="apellidos">
            <input type="number" placeholder="Dorsal" class="form-control my-2" name="dorsal">
            <input type="date" placeholder="Fecha Nacimiento" class="form-control my-2" name="fecha_nacimiento">
            <select class="form-control my-2" name="posicion">
                <option value="">Selecciona Posición</option>
                <option value="Portero">Portero</option>
                <option value="Defensa">Defensa</option>
                <option value="Centrocampista">Centrocampista</option>
                <option value="Delantero">Delantero</option>
            </select>
            <input type="text" placeholder="Equipo" class="form-control my-2" name="equipo">
            <select class="form-control my-2" name="estado_fisico">
                <option value="">Selecciona Estado Físico</option>
                <option value="Disponible">Disponible</option>
                <option value="Lesionado">Lesionado</option>
                <option value="En recuperación">En recuperación</option>
                <option value="Sancionado">Sancionado</option>
            </select>
            <button type="submit" class="btn btn-dark btn-block">
                Agregar
            </button>
        </form>
    </div>
<%- include("templates/footer") %>